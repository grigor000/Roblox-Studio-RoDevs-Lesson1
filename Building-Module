local module = {}

module.Config = {
	MaxSize = 100,
	MinSize = 1,
	AutoWeld = true,
	KillOnTouch = true,
}

function module.ClampSize(size)
	return Vector3.new(
		math.clamp(size.X, module.Config.MinSize, module.Config.MaxSize),
		math.clamp(size.Y, module.Config.MinSize, module.Config.MaxSize),
		math.clamp(size.Z, module.Config.MinSize, module.Config.MaxSize)
	)
end

function module.CreatePart(size, color, shape)
	local part = Instance.new("Part")
	part.Size = module.ClampSize(size)
	part.BrickColor = color
	part.Anchored = false
	part.CanCollide = true
	part.Shape = shape
	part.Parent = workspace
	return part
end

function module.ApplyPlacement(part, cframe)
	part.CFrame = cframe
end

function module.AddWeldOnTouch(part)
	local con
	con = part.Touched:Connect(function(hit)
		if not hit or not hit.Parent then return end

		local hum = hit.Parent:FindFirstChildOfClass("Humanoid")

		if hum then
			part:Destroy()
			return
		end

		if module.Config.AutoWeld then
			local weld = Instance.new("WeldConstraint")
			weld.Part0 = part
			weld.Part1 = hit
			weld.Parent = part
		end

		con:Disconnect()
	end)
end

function module.Place(plr, cframe, size, color, shape)
	local part = module.CreatePart(size, color, shape)

	module.ApplyPlacement(part, cframe)

	if module.Config.AutoWeld or module.Config.KillOnTouch then
		module.AddWeldOnTouch(part)
	end

	part:SetAttribute("Owner", plr.UserId)

	return part
end

return module
